APP_NAME=Aveti Transcripts
DATABASE_URL=postgresql+psycopg://grammar:CHANGE_ME@127.0.0.1:5432/grammar
ADMIN_KEY=CHANGE_ME_LONG_RANDOM_VALUE
DISPLAY_TIMEZONE=Asia/Kolkata

YOUTUBE_FALLBACK_ENABLED=true
YOUTUBE_LANGUAGES=en,en-IN,hi
REQUEST_DELAY_SECONDS=0.25
WORKER_POLL_SECONDS=2

AUDIO_TRANSCRIPTION_ENABLED=true
AUDIO_TRANSCRIPTION_MAX_DURATION_SECONDS=3600
FASTER_WHISPER_MODEL=tiny
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

# Free local embeddings. pgvector can index these when the database extension is installed.
EMBEDDING_DIMENSIONS=128
PGVECTOR_ENABLED=false
